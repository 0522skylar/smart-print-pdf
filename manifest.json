{
  "manifest_version": 3,
  "name": "Smart Print to PDF",
  "version": "1.1.0",
  "description": "智能 HTML 转 PDF —— 打印前可视化设置面板，支持纸张/方向/边距/页眉页脚，4 种打印模式。",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "智能打印 PDF",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "styles/print-optimize.css",
        "lib/html2canvas.min.js",
        "lib/jspdf.umd.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
